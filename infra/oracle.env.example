# Host ports
API_PORT_HOST=3000
WORKER_PORT_HOST=10000
MONGO_PORT=27017
MQTT_PORT_HOST=1883

# Core app config
# Use local Mongo by default; replace with Atlas URI when needed.
MONGODB_URI=mongodb://mongo:27017
# Use an isolated DB per environment (ex: hermit-home-prod).
MONGODB_DB_NAME=hermit-home-prod
MONGODB_MAX_POOL_SIZE=10
TZ=Asia/Ho_Chi_Minh
SERVICE_API_KEY=replace_with_long_random_secret
JWT_SECRET=replace_with_long_random_secret

# MQTT connection used by API + worker.
# Local broker mode:
#   MQTT_PROTOCOL=mqtt
#   MQTT_BROKER=mosquitto
#   MQTT_PORT=1883
# HiveMQ cloud mode:
#   MQTT_PROTOCOL=mqtts
#   MQTT_BROKER=<your-cluster>.hivemq.cloud
#   MQTT_PORT=8883
MQTT_PROTOCOL=mqtt
MQTT_BROKER=mosquitto
MQTT_PORT=1883
MQTT_USER=
MQTT_PASS=
MQTT_CA_CERT=

# Optional auth integrations
FIREBASE_SERVICE_ACCOUNT_KEY=

# Password reset mail (optional)
PASSWORD_RESET_URL=https://your-domain/reset-password
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Safety/runtime tuning
EDGE_ACK_TIMEOUT_MS=12000
USER_OVERRIDE_GRACE_SECONDS=300
ALLOWED_DEVICE_IDS=
ENFORCE_ALLOWED_DEVICE_IDS=false
AGENT_CONTROL_ENFORCE_ALLOWED_DEVICE_IDS=false
AGENT_CONTROL_MAX_DEVICES=30
AGENT_CONTROL_ACTIVE_WINDOW_SECONDS=900
AGENT_CONTROL_RECENT_WINDOW_SIZE=24
AGENT_CONTROL_ALERTS_ENABLED=true
AGENT_MIST_SAFETY_LOCK_ENABLED=true
AGENT_EMERGENCY_RELEASE_DELAY_MS=2000

# Worker runtime
LOG_LEVEL=info
SELF_PING_INTERVAL_MS=180000
SELF_PING_TIMEOUT_MS=10000
AGENT_CONTROL_ENABLED=false
AGENT_CONTROL_METHOD=POST
AGENT_CONTROL_INTERVAL_MS=20000
AGENT_CONTROL_TIMEOUT_MS=8000
AGENT_CONTROL_BODY_JSON={"source":"mqtt-worker","trigger":"interval"}

# Optional LLM/chatbox
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_CHAT_MODEL=google/gemma-4-26b-a4b-it:free
OPENROUTER_CHAT_TEMPERATURE=0.2
OPENROUTER_CHAT_MAX_TOKENS=700
CHATBOX_TELEMETRY_WINDOW_SIZE=24
CHATBOX_TELEMETRY_CSV_PATH=exports/telemetry-export.csv
CHATBOX_TELEMETRY_CSV_SAMPLE_SIZE=400
CHATBOX_MAX_HISTORY_TURNS=8
CHATBOX_MAX_SUGGESTIONS=5
