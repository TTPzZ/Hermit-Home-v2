# ==========================================
# Copy this file to each service directory:
# - services/api/.env
# - services/mqtt-worker/.env
# - services/ai-agent/.env
# ==========================================

# --- Database (MongoDB) ---
MONGODB_URI="mongodb+srv://<replace_user>:<replace_pass>@cluster.mongodb.net/?retryWrites=true&w=majority"
# Suggested naming:
# - hermit-home-local
# - hermit-home-staging
# - hermit-home-prod
MONGODB_DB_NAME="hermit-home-local"
MONGODB_MAX_POOL_SIZE=10

# --- MQTT Broker (EMQX Cloud Serverless) ---
# EMQX Serverless requires MQTT over TLS on port 8883.
# MQTT_BROKER must be the host from EMQX only, without mqtts://, https://, path, or CNAME.
MQTT_PROTOCOL="mqtts"
MQTT_BROKER="<replace_with_emqx_broker_host>"
MQTT_PORT=8883
MQTT_USER="<replace_with_emqx_username>"
MQTT_PASS="<replace_with_emqx_password>"
# Optional custom root CA certificate in PEM format, newline escaped.
# Leave empty when the runtime trusts the EMQX server certificate chain.
MQTT_CA_CERT=""

# --- API Auth ---
# Shared secret used by service-to-service calls (AI agent -> API).
SERVICE_API_KEY="<replace_with_long_random_secret>"
# JWT signing secret for /api/users/login and internal Bearer-token verification.
JWT_SECRET="<replace_with_long_random_secret>"
# Required only for Firebase Bearer-token verification path.
FIREBASE_SERVICE_ACCOUNT_KEY=""

# --- Password reset email ---
# Frontend/app URL that receives the reset token as a query param.
# For this Vercel API, use the reset-link route so the email opens a browser
# first, validates the token, then redirects into the Flutter app deep link.
# Example: https://your-vercel-domain.vercel.app/reset-password
PASSWORD_RESET_URL=""
# Deep link used by the API after the reset link is validated.
PASSWORD_RESET_APP_DEEP_LINK_URL="hermithome://reset-password"
# Token expiry window for reset links.
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
# SMTP config used to send reset email.
SMTP_HOST=""
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=""
SMTP_PASS=""
# Example: Hermit Home <no-reply@your-domain.com>
SMTP_FROM=""

# --- Worker Authorization ---
# Optional comma-separated list of authorized MongoDB ObjectId values.
# Leave empty for dynamic onboarding flow.
ALLOWED_DEVICE_IDS=""
# Set true only when you want strict device whitelist enforcement.
ENFORCE_ALLOWED_DEVICE_IDS=false

# --- AI Agent Variables ---
API_BASE_URL="http://localhost:3000"
DEVICE_ID="<replace_with_test_device_id>"
HTTP_TIMEOUT_SECONDS=10
CONTROL_INTERVAL_SECONDS=30
TELEMETRY_WINDOW_SIZE=12
TELEMETRY_CSV_PATH="../../exports/telemetry-export.csv"
MIST_SAFETY_LOCK_ENABLED=true
EMERGENCY_RELEASE_DELAY_SECONDS=2
USER_OVERRIDE_TAKEOVER_DELAY_SECONDS=20
OPENROUTER_API_KEY="<replace_with_openrouter_api_key>"
OPENROUTER_MODEL="google/gemma-3-27b-it:free"
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
# Optional for OpenRouter analytics/ranking
OPENROUTER_HTTP_REFERER=""
OPENROUTER_APP_NAME="Hermit Home AI Agent"

# --- mqtt-worker self keepalive (Render web service) ---
# If SELF_PING_URL is empty, worker falls back to ${RENDER_EXTERNAL_URL}/ping
SELF_PING_URL=""
SELF_PING_INTERVAL_MS=180000
SELF_PING_TIMEOUT_MS=10000

# --- mqtt-worker -> agent API trigger loop (temporary bridge) ---
# Enable periodic API trigger so agent can execute control cycle continuously.
AGENT_CONTROL_ENABLED=false
# Example (this repo): https://hermithomev2.vercel.app/api/agent/control/cycle
AGENT_CONTROL_URL=""
# Optional override. Supported: POST (default), GET
AGENT_CONTROL_METHOD=POST
# Use the same shared SERVICE_API_KEY that Vercel API expects.
AGENT_CONTROL_API_KEY=""
# Trigger cadence. Recommended default: 20000 (20s) to keep control responsive.
AGENT_CONTROL_INTERVAL_MS=20000
AGENT_CONTROL_TIMEOUT_MS=8000
# Optional custom POST payload (must be valid JSON object/string).
# If payload omits deviceId, API will auto-resolve devices from latest telemetry.
AGENT_CONTROL_BODY_JSON="{\"source\":\"mqtt-worker\",\"trigger\":\"interval\"}"

# --- Vercel API: /api/agent/control/cycle runtime tuning ---
# Maximum number of auto-resolved devices per cycle when deviceId is not provided.
AGENT_CONTROL_MAX_DEVICES=30
# Auto-target only devices that have telemetry within this window (seconds).
# Set 0 to disable freshness filtering.
AGENT_CONTROL_ACTIVE_WINDOW_SECONDS=900
# User manual override grace window in seconds (default 5 minutes).
USER_OVERRIDE_GRACE_SECONDS=300
# Optional strict allow-list filter for service-key multi-device cycles.
AGENT_CONTROL_ENFORCE_ALLOWED_DEVICE_IDS=false
AGENT_CONTROL_RECENT_WINDOW_SIZE=24
AGENT_MIST_SAFETY_LOCK_ENABLED=true
AGENT_EMERGENCY_RELEASE_DELAY_MS=2000
# CSV context is optional. If file doesn't exist, control cycle still runs.
AGENT_TELEMETRY_CSV_PATH="exports/telemetry-export.csv"
AGENT_TELEMETRY_CSV_SAMPLE_SIZE=600
AGENT_CONTROL_ALERTS_ENABLED=true

# --- Vercel API: chatbox (OpenRouter) ---
OPENROUTER_API_KEY="<replace_with_openrouter_api_key>"
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
# Optional prioritized model list (CSV) for automatic failover in chatbox API.
# Example:
# OPENROUTER_CHAT_MODELS="google/gemma-4-26b-a4b-it:free,google/gemma-4-31b-it:free"
OPENROUTER_CHAT_MODEL="google/gemma-4-26b-a4b-it:free"
# Optional for OpenRouter ranking/analytics
OPENROUTER_HTTP_REFERER=""
OPENROUTER_APP_NAME="Hermit Home Chatbox"
OPENROUTER_CHAT_TEMPERATURE=0.2
OPENROUTER_CHAT_MAX_TOKENS=700
CHATBOX_TELEMETRY_WINDOW_SIZE=24
CHATBOX_TELEMETRY_CSV_PATH="exports/telemetry-export.csv"
CHATBOX_TELEMETRY_CSV_SAMPLE_SIZE=400
CHATBOX_MAX_HISTORY_TURNS=8
CHATBOX_MAX_SUGGESTIONS=5
