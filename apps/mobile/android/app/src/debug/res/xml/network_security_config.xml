<?xml version="1.0" encoding="utf-8"?>
<!--
  Debug-only network security config.
  Allows cleartext HTTP for local backend testing on real devices where
  the backend IP can change between sessions.
  Release build still uses src/main config.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
