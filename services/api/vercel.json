{
  "version": 2,
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, PUT, PATCH, DELETE, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, Authorization, Accept, X-API-Key"
        },
        {
          "key": "Access-Control-Max-Age",
          "value": "86400"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/reset-password", "destination": "/api/auth?action=reset-link" },
    { "source": "/reset-password/", "destination": "/api/auth?action=reset-link" },
    {
      "source": "/api/devices/:deviceId/status",
      "destination": "/api/devices/:deviceId/data?type=latest"
    },
    {
      "source": "/api/devices/:deviceId/telemetry",
      "destination": "/api/devices/:deviceId/data?type=history"
    },
    {
      "source": "/api/devices/:deviceId/control",
      "destination": "/api/devices/:deviceId/action?type=control"
    },
    {
      "source": "/api/devices/:deviceId/override",
      "destination": "/api/devices/:deviceId/action?type=override"
    },
    {
      "source": "/api/devices/:deviceId/alerts",
      "destination": "/api/devices/:deviceId/action?type=alert"
    },
    { "source": "/api/users/register", "destination": "/api/auth?action=register" },
    { "source": "/api/users/login", "destination": "/api/auth?action=login" },
    { "source": "/api/users/forgot-password", "destination": "/api/auth?action=forgot-password" },
    { "source": "/api/users/reset-password", "destination": "/api/auth?action=reset-password" },
    { "source": "/api/users/password-reset", "destination": "/api/auth?action=password-reset" },
    {
      "source": "/api/users/validate-reset-token",
      "destination": "/api/auth?action=validate-reset-token"
    },
    { "source": "/api/users/reset-password-link", "destination": "/api/auth?action=reset-link" },
    { "source": "/api/(.*)", "destination": "/api/$1" }
  ]
}
