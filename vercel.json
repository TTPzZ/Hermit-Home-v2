{
  "version": 2,
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, PUT, PATCH, DELETE, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, Authorization, Accept, X-API-Key"
        },
        {
          "key": "Access-Control-Max-Age",
          "value": "86400"
        }
      ]
    }
  ],
  "builds": [
    {
      "src": "services/api/api/**/*.ts",
      "use": "@vercel/node"
    },
    {
      "src": "services/api/public/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/reset-password",
      "dest": "/services/api/api/auth/index.ts?action=reset-link"
    },
    {
      "src": "/reset-password/",
      "dest": "/services/api/api/auth/index.ts?action=reset-link"
    },
    {
      "src": "/api/auth",
      "dest": "/services/api/api/auth/index.ts"
    },
    {
      "src": "/api/users/forgot-password",
      "dest": "/services/api/api/auth/index.ts?action=forgot-password"
    },
    {
      "src": "/api/users/reset-password",
      "dest": "/services/api/api/auth/index.ts?action=reset-password"
    },
    {
      "src": "/api/users/validate-reset-token",
      "dest": "/services/api/api/auth/index.ts?action=validate-reset-token"
    },
    {
      "src": "/api/users/password-reset",
      "dest": "/services/api/api/auth/index.ts?action=password-reset"
    },
    {
      "src": "/api/users/reset-password-link",
      "dest": "/services/api/api/auth/index.ts?action=reset-link"
    },
    {
      "src": "/api/users/login",
      "dest": "/services/api/api/auth/index.ts?action=login"
    },
    {
      "src": "/api/users/register",
      "dest": "/services/api/api/auth/index.ts?action=register"
    },
    {
      "src": "/api/agent/control/cycle",
      "dest": "/services/api/api/agent/control/cycle.ts"
    },
    {
      "src": "/api/emqx/telemetry",
      "dest": "/services/api/api/emqx/telemetry.ts"
    },
    {
      "src": "/api/emqx/confirm",
      "dest": "/services/api/api/emqx/confirm.ts"
    },
    {
      "src": "/api/devices/([^/]+)/data",
      "dest": "/services/api/api/devices/[deviceId]/data.ts?deviceId=$1"
    },
    {
      "src": "/api/devices/([^/]+)/status",
      "dest": "/services/api/api/devices/[deviceId]/data.ts?deviceId=$1&type=latest"
    },
    {
      "src": "/api/devices/([^/]+)/telemetry",
      "dest": "/services/api/api/devices/[deviceId]/data.ts?deviceId=$1&type=history"
    },
    {
      "src": "/api/devices/([^/]+)/action",
      "dest": "/services/api/api/devices/[deviceId]/action.ts?deviceId=$1"
    },
    {
      "src": "/api/devices/([^/]+)/chatbox",
      "dest": "/services/api/api/devices/[deviceId]/chatbox.ts?deviceId=$1"
    },
    {
      "src": "/api/devices/([^/]+)/override",
      "dest": "/services/api/api/devices/[deviceId]/action.ts?deviceId=$1&type=override"
    },
    {
      "src": "/api/devices/([^/]+)/control",
      "dest": "/services/api/api/devices/[deviceId]/action.ts?deviceId=$1&type=control"
    },
    {
      "src": "/api/devices/([^/]+)/alerts",
      "dest": "/services/api/api/devices/[deviceId]/action.ts?deviceId=$1&type=alert"
    },
    {
      "src": "/api/devices/schedules",
      "dest": "/services/api/api/devices/schedules/index.ts"
    },
    {
      "src": "/api/devices/([^/]+)",
      "dest": "/services/api/api/devices/[deviceId]/index.ts?deviceId=$1"
    },
    {
      "src": "/api/devices",
      "dest": "/services/api/api/devices/index.ts"
    },
    {
      "src": "/api/logs",
      "dest": "/services/api/api/logs.ts"
    },
    {
      "src": "/images/(.*)",
      "dest": "/services/api/public/images/$1"
    },
    {
      "src": "/",
      "dest": "/services/api/public/index.html"
    }
  ]
}
